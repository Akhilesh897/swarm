APP_NAME=Enterprise Multi-Agent Copilot
APP_ENV=dev

# Model APIs (optional, but recommended for final answer synthesis)
GROK_API_URL=https://api.x.ai/v1/chat/completions
Gemini_MODEL=
GROK_MODEL=grok-2
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/{model}:generateContent
Grok_MODEL=
GEMINI_MODEL=gemini-1.5-flash

# Power Automate triggers
POWER_AUTOMATE_EMAIL_URL=
POWER_AUTOMATE_IT_URL=
MANAGER_EMAIL=

# Data paths
APP_DB_PATH=./data/app.db
VECTOR_DB_PATH=./data/vector_db
HR_DOCS_PATH=./data/docs
HOLIDAY_CALENDAR_PATH=./data/holiday_calendar.json

# Embeddings and reranking
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_ENABLED=true
ALLOW_EMBEDDING_MODEL_DOWNLOAD=false
SEMANTIC_CACHE_THRESHOLD=0.9
SEMANTIC_CACHE_SIZE=200

# Security
JWT_SECRET=replace_me
INVENTORY_MIN_STOCK=1
COMPANY_EMAIL_DOMAIN=company.com
ADMIN_EMAIL_ROLES={"manager@company.com":"manager","itlead@company.com":"it_lead"}
